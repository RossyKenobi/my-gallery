---
export const prerender = true;
import '../styles/global.css';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <title>404 — THE GALLERY</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  </head>
  <body class="page-404">
    <img src="/images/hero_background.jpg" class="fourohfour-bg" alt="Background" />
    <div class="fourohfour-overlay"></div>
    <div class="fourohfour-container">
      <div class="fourohfour-card">
        <h1 class="fourohfour-code">404</h1>
        <p class="fourohfour-text">PAGE NOT FOUND</p>
        <p class="fourohfour-sub">The page you're looking for doesn't exist<br/>or has been moved.</p>
        <a href="/" class="fourohfour-btn">Return Home</a>
      </div>
    </div>

    <style is:global>
      .page-404 {
        margin: 0;
        height: 100vh;
        overflow: hidden;
        position: relative;
      }
      .fourohfour-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        object-fit: cover;
        z-index: 0;
      }
      .fourohfour-overlay {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(15px);
        -webkit-backdrop-filter: blur(15px);
        z-index: 0;
      }
      .fourohfour-container {
        position: relative;
        z-index: 1;
        width: 100%;
        height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .fourohfour-card {
        background: rgba(255, 255, 255, 0.03);
        backdrop-filter: blur(24px);
        -webkit-backdrop-filter: blur(24px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 24px;
        padding: 3.5rem 4rem;
        text-align: center;
        max-width: 450px;
        width: 90%;
        box-shadow: 0 20px 60px rgba(0,0,0,0.4);
        transform: translateY(-5vh);
      }
      .fourohfour-code {
        font-family: 'Cormorant Garamond', serif;
        font-size: clamp(5rem, 12vw, 8rem);
        font-weight: 700;
        color: rgba(255, 255, 255, 0.08); /* Increased visibility slightly while keeping ghostly look */
        margin: 0 0 2rem;
        line-height: 1;
        letter-spacing: 0.05em;
      }
      .fourohfour-text {
        font-family: 'Montserrat', sans-serif;
        font-size: 1rem;
        font-weight: 400;
        letter-spacing: 0.3em;
        color: rgba(255, 255, 255, 0.7);
        margin: 0 0 1rem;
        text-transform: uppercase;
      }
      .fourohfour-sub {
        font-family: 'Montserrat', sans-serif;
        font-size: 0.8rem;
        color: rgba(255, 255, 255, 0.35);
        letter-spacing: 0.05em;
        line-height: 1.6;
        margin: 0 0 2.5rem;
      }
      .fourohfour-btn {
        display: inline-block;
        background: rgba(255, 255, 255, 0.9);
        color: #0a0a0a;
        text-decoration: none;
        font-family: 'Montserrat', sans-serif;
        font-size: 0.75rem;
        font-weight: 600;
        letter-spacing: 0.15em;
        text-transform: uppercase;
        padding: 0.85rem 2.5rem;
        border-radius: 40px;
        transition: all 0.3s ease;
      }
      .fourohfour-btn:hover {
        background: white;
        transform: translateY(-2px);
        box-shadow: 0 8px 25px rgba(255,255,255,0.1);
      }
    </style>
  </body>
</html>
