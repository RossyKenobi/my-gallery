      // --- R2 Upload Helpers ---
      const MAX_IMAGE_DIMENSION = 2400; // px, longest side
      const JPEG_QUALITY = 0.85;

      async function compressImage(file) {
        return new Promise((resolve, reject) => {
          const img = new Image();
          img.onload = () => {
            let { width, height } = img;
            // Scale down if larger than max dimension
            if (width > MAX_IMAGE_DIMENSION || height > MAX_IMAGE_DIMENSION) {
              if (width > height) {
                height = Math.round(height * (MAX_IMAGE_DIMENSION / width));
                width = MAX_IMAGE_DIMENSION;
              } else {
                width = Math.round(width * (MAX_IMAGE_DIMENSION / height));
                height = MAX_IMAGE_DIMENSION;
              }
            }
            const canvas = document.createElement('canvas');
            canvas.width = width;
            canvas.height = height;
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, width, height);
            canvas.toBlob(
              (blob) => {
                if (blob) resolve(blob);
                else reject(new Error('Compression failed'));
              },
              'image/jpeg',
              JPEG_QUALITY
            );
            URL.revokeObjectURL(img.src);
          };
          img.onerror = () => reject(new Error('Failed to load image'));
          img.src = URL.createObjectURL(file);
        });
      }

      async function uploadToR2(file, filename) {
        // Compress image before uploading
        const compressed = await compressImage(file);
        console.log(`Compressed: ${(file.size/1024/1024).toFixed(1)}MB → ${(compressed.size/1024/1024).toFixed(1)}MB`);

        const formData = new FormData();
        formData.append('filename', filename);
        formData.append('file', compressed, filename);

        const res = await fetch(UPLOAD_API, {
          method: 'POST',
          body: formData,
        });

        const data = await res.json().catch(() => null);
        if (!res.ok || !data) {
          throw new Error((data && data.error) || `Upload failed (HTTP ${res.status})`);
        }
        return data.finalImageUrl;
      }

      function dataUrlToBlob(dataUrl) {
        const [header, base64] = dataUrl.split(',');
        const mime = header.match(/:(.*?);/)[1];
        const binary = atob(base64);
        const array = new Uint8Array(binary.length);
        for (let i = 0; i < binary.length; i++) array[i] = binary.charCodeAt(i);
        return new Blob([array], { type: mime });
      }

      async function savePostsToR2(posts) {
        const res = await fetch(POSTS_API, {
          method: 'PUT',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(posts),
        });
        if (!res.ok) throw new Error('Failed to save posts');
      }

      // --- New Local Upload (R2) ---
      async function handleLocalUpload() {
        const files = Array.from(fileInput.files || []);
        const caption = document.getElementById('local-caption-input').value;
        const author = document.getElementById('local-author-input').value;
        if (files.length === 0) return;

        openModal(progressModal);
        progressTitle.innerText = 'Importing...';
        progressStatusText.innerText = 'Uploading images...';
        progressBarInner.style.width = '10%';

        const timestamp = Date.now();
        const postId = `local-${timestamp}`;
        const imageUrls = [];
        let isPortrait = false;

        try {
          // Pre-calculate physical orientation of the primary image for perfect grid masonry placement
          if (files[0]) {
            const img = new Image();
            img.src = URL.createObjectURL(files[0]);
            await new Promise(r => {
               img.onload = r;
               img.onerror = r; 
            });
            isPortrait = (img.naturalHeight > img.naturalWidth);
          }

          for (let i = 0; i < files.length; i++) {
            const file = files[i];
            const fileName = `p_local_${timestamp}_${i}.jpg`;
            progressStatusText.innerText = `Uploading image ${i + 1}/${files.length}...`;
            progressBarInner.style.width = `${10 + ((i + 1) / files.length) * 50}%`;
            const finalUrl = await uploadToR2(file, fileName);
            imageUrls.push(finalUrl);
          }

          progressStatusText.innerText = 'Saving post...';
          progressBarInner.style.width = '80%';

          const newPost = {
            id: postId,
            caption: caption,
            author: author,
            timestamp: new Date().toISOString(),
            images: imageUrls,
            hidden: false,
            category: 'General',
            isPortrait: isPortrait,
          };

          // Create the new stack in DB via dedicated endpoint
          const createRes = await fetch('/api/stacks', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(newPost),
          });
          if (!createRes.ok) {
            const errData = await createRes.json();
            throw new Error(errData.error || 'Failed to create stack');
