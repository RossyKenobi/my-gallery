---
import '../styles/global.css';
import GalleryPost from '../components/GalleryPost.astro';
import postsData from '../data/posts.json';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const posts = (postsData || []).map(post => ({
  ...post,
  images: (post.images || []).map(img => `${base}${img.startsWith('/') ? img.slice(1) : img}`)
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Instagram Portfolio</title>
    <!-- PhotoSwipe CSS -->
    <link rel="stylesheet" href="https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.css">
  </head>
  <body>
    <!-- Transparent Minimalist Navigation -->
    <nav class="minimal-nav">
      <div class="nav-brand">F.Y.</div>
      <div class="nav-links">
        <a href="#gallery" class="nav-link">Work</a>
        <a href="#contact" class="nav-link">Contact</a>
      </div>
    </nav>

    <!-- Full-Screen Hero Section -->
    <header class="hero-section">
      <img src="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?auto=format&fit=crop&q=80" alt="Architecture" class="hero-bg" />
      <div class="hero-content">
        <h1 class="hero-title">Selected Works</h1>
        <p class="hero-subtitle">Visual exploration and storytelling.</p>
      </div>
    </header>

    <main class="gallery-grid" id="gallery">
      {posts.map(post => (
        <GalleryPost post={post} />
      ))}
    </main>

    <div class="gallery-bottom-bar">
        <div class="edit-controls">
          <button class="action-btn" id="open-edit-mode">Edit</button>
          <div id="edit-actions" class="hidden" style="display:flex; gap:1.5rem">
            <button class="action-btn" id="cancel-edits">Cancel</button>
            <button class="action-btn" id="save-edits">Done</button>
            <button class="action-btn confirm" id="add-new-post">Import</button>
          </div>
        </div>
      </div>
      <div class="gallery-divider"></div>

    <section id="contact" class="contact-section">
      <div class="contact-container">
        <p class="contact-title">C O N T A C T</p>
          <div class="contact-links">
            <a href="mailto:SMYFY1@OUTLOOK.COM" class="contact-link">
              <svg viewBox="0 0 24 24"><path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              SMYFY1@OUTLOOK.COM
            </a>
            <a href="https://instagram.com/THEONLYYFF" target="_blank" rel="noopener noreferrer" class="contact-link">
              <svg viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              @THEONLYYFF
            </a>
          </div>
        </div>
      </section>

    <!-- Password Modal (Minimalist) -->
    <div class="modal-overlay" id="password-modal">
      <div class="modal-content">
        <h3 class="modal-title">Verification Required</h3>
        <div class="modal-input-group" style="margin-top:2.5rem;">
          <label class="modal-caption">Enter Administrative Password</label>
          <input type="password" id="password-input" class="modal-input" placeholder="••••••••" />
          <div id="password-error" class="error-msg">Incorrect password.</div>
        </div>
        <div class="modal-actions" style="margin-top:3rem;">
          <button class="modal-btn" id="close-password-modal">Cancel</button>
          <button class="modal-btn confirm" id="submit-password">Verify</button>
        </div>
      </div>
    </div>

    <!-- Import Modal -->
    <div class="modal-overlay" id="import-modal">
      <div class="modal-content">
        <h3 class="modal-title">Import New Work</h3>

        <div id="local-tab" class="tab-content active">
          <div class="modal-input-group">
            <label class="modal-caption">select images</label>
            <input type="file" id="local-file-input" class="modal-input" multiple accept="image/*" />
            <div id="file-preview" class="file-preview-grid"></div>
            <textarea id="local-caption-input" class="modal-input" placeholder="Add a caption..."></textarea>
          </div>
        </div>

        <div class="modal-actions">
          <button class="modal-btn" id="close-import-modal">Cancel</button>
          <button class="modal-btn confirm" id="confirm-import">Confirm</button>
        </div>
      </div>
    </div>


    <!-- Progress Modal -->
    <div class="modal-overlay" id="progress-modal">
      <div class="modal-content">
        <h3 class="modal-title" id="progress-title">Importing...</h3>
        <div class="progress-container">
          <div class="progress-bar" id="progress-bar-inner"></div>
        </div>
        <p class="progress-status" id="progress-status-text">Checking GitHub status...</p>
        <div class="modal-actions" style="justify-content: center;">
          <button class="refresh-btn" id="refresh-page-btn">Refresh to see changes</button>
        </div>
      </div>
    </div>

    <style is:global>
      /* --- Hero Scroll Effect --- */
      .hero-section {
        position: relative;
        height: 100vh;
        width: 100%;
        overflow: hidden;
      }
      .hero-bg {
        position: fixed; /* Parallax effect */
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        object-fit: cover;
        z-index: -2;
      }
      .hero-overlay-blur {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background: rgba(0, 0, 0, 0);
        backdrop-filter: blur(0px);
        z-index: -1;
        pointer-events: none;
        transition: backdrop-filter 0.1s linear, background 0.1s linear;
      }

      /* --- Edit Mode Styles --- */
      body.is-editing .gallery-item-wrapper {
        cursor: grab;
      }
      body.is-editing .sortable-ghost {
        opacity: 0.5;
        border: 2px dashed rgba(255, 255, 255, 0.5);
        border-radius: 4px;
      }
      body.is-editing .sortable-drag {
        cursor: grabbing !important;
      }
      body.is-editing .delete-btn {
        display: flex !important;
        opacity: 1 !important;
        background: #ef4444 !important;
      }
      .hidden { display: none !important; }

      /* --- Contact List --- */
      .contact-list {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        margin-bottom: 40px;
      }
      .contact-item {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .contact-icon {
        width: 20px;
        height: 20px;
        opacity: 0.6;
      }
      .contact-item a {
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-decoration: none;
        color: white;
        font-size: 0.9rem;
      }

      /* --- Import Modal Tabs --- */
      .import-tabs {
        display: flex;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        margin-bottom: 24px;
      }
      .tab-btn {
        background: none;
        border: none;
        color: rgba(255,255,255,0.5);
        padding: 12px 24px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: color 0.3s;
      }
      .tab-btn.active {
        color: white;
        border-bottom: 2px solid white;
      }
      .tab-content { display: none; }
      .tab-content.active { display: block; }

      /* --- PhotoSwipe Carousel Look --- */
      .pswp__img {
        border-radius: 4px;
        box-shadow: 0 10px 50px rgba(0,0,0,0.5);
      }
      /* Ensure side images are slightly visible */
      .pswp__item {
        padding: 0 10% !important;
      }

    </style>

    <script>
      import PhotoSwipe from 'photoswipe';
      import Sortable from 'sortablejs';

      // --- Hero Scroll Logic ---
      const heroOverlay = document.createElement('div');
      heroOverlay.className = 'hero-overlay-blur';
      document.body.prepend(heroOverlay);

      window.addEventListener('scroll', () => {
        const scrollY = window.scrollY;
        const viewportHeight = window.innerHeight;
        
        // Cap the progress so it doesn't get completely dark
        const progress = Math.min(scrollY / (viewportHeight * 0.8), 1);
        
        // Start brightness at 0.35 opacity and go up to 0.60
        const opacity = 0.35 + (progress * 0.25);
        
        heroOverlay.style.background = `rgba(0, 0, 0, ${opacity})`; 
        heroOverlay.style.backdropFilter = `blur(${progress * 20}px)`;
      });
      // Initial trigger
      heroOverlay.style.background = `rgba(0, 0, 0, 0.35)`;
      heroOverlay.style.backdropFilter = `blur(0px)`;

      // --- Modals & DOM Elements Initialization ---
      const passwordModal = document.getElementById('password-modal')!;
      const importModal = document.getElementById('import-modal')!;
      const progressModal = document.getElementById('progress-modal')!;
      const passwordInput = document.getElementById('password-input') as HTMLInputElement;
      const embedKeyInput = document.getElementById('embed-key-input') as HTMLInputElement;
      const fileInput = document.getElementById('local-file-input') as HTMLInputElement;
      const preview = document.getElementById('file-preview')!;
      const progressBarInner = document.getElementById('progress-bar-inner')!;
      const progressStatusText = document.getElementById('progress-status-text')!;
      const progressTitle = document.getElementById('progress-title')!;
      const refreshPageBtn = document.getElementById('refresh-page-btn') as HTMLButtonElement;

      const openModal = (modal: HTMLElement) => {
        modal.classList.add('active');
      };
      const closeModal = (modal: HTMLElement) => {
        modal.classList.remove('active');
        if (passwordInput) passwordInput.value = '';
        if (embedKeyInput) embedKeyInput.value = '';
        if (preview) preview.innerHTML = '';
      };

      document.getElementById('close-password-modal')?.addEventListener('click', () => closeModal(passwordModal));
      document.getElementById('close-import-modal')?.addEventListener('click', () => closeModal(importModal));
      refreshPageBtn?.addEventListener('click', () => window.location.reload());

      // --- Edit Mode Logic ---
      const GITHUB_TOKEN_KEY = 'gh_admin_token';
      const PASSWORD = 'steveyfff';
      let isEditMode = false;
      let sortableInstance: any = null;
      let pendingAction: 'IMPORT' | 'DELETE' | 'ENTER_EDIT' | 'REORDER' | null = null;
      let pendingPostId: string | null = null;
      let initialOrder: string[] = [];

      const editBtn = document.getElementById('open-edit-mode')!;
      const editActions = document.getElementById('edit-actions')!;
      const saveBtn = document.getElementById('save-edits')!;
      const cancelBtn = document.getElementById('cancel-edits')!;
      const addBtn = document.getElementById('add-new-post')!;

      editBtn.addEventListener('click', () => {
        if (!isEditMode) {
          pendingAction = 'ENTER_EDIT';
          openModal(passwordModal);
        }
      });

      cancelBtn.addEventListener('click', () => {
        if (confirm("All unsaved changes will be discarded. Are you sure you want to cancel?")) {
          window.location.reload();
        }
      });

      // Update password submission
      document.getElementById('submit-password')?.addEventListener('click', () => {
        const passwordInput = document.getElementById('password-input') as HTMLInputElement;
        const errorEl = document.getElementById('password-error')!;
        if (passwordInput.value === PASSWORD) {
          errorEl.classList.remove('show');
          closeModal(passwordModal);
          
          if (pendingAction === 'ENTER_EDIT') {
            enterEditMode();
          } else if (pendingAction === 'IMPORT') {
            openModal(importModal);
          } else if (pendingAction === 'DELETE') {
            handleGithubAction('DELETE', null, pendingPostId);
          }
        } else {
          errorEl.classList.add('show');
        }
      });

      function enterEditMode() {
        isEditMode = true;
        document.body.classList.add('is-editing');
        editBtn.classList.add('hidden');
        editActions.classList.remove('hidden');

        const orderNodes = Array.from(document.querySelectorAll('.gallery-item-wrapper'));
        initialOrder = orderNodes.map(node => node.getAttribute('data-id') || '');

        const el = document.getElementById('gallery')!;
        sortableInstance = new Sortable(el, {
          animation: 150,
          ghostClass: 'sortable-ghost'
        });
      }

      saveBtn.addEventListener('click', async () => {
        const orderNodes = Array.from(document.querySelectorAll('.gallery-item-wrapper'));
        const newOrder = orderNodes.map(node => node.getAttribute('data-id') || '');
        
        if (newOrder.join(',') === initialOrder.join(',')) {
          console.log("No changes detected. Exiting edit mode silently.");
          exitEditMode();
          return;
        }
        
        // We'll trigger a workflow to reorder the JSON
        handleGithubAction('REORDER', JSON.stringify(newOrder), null);
        exitEditMode();
      });

      function exitEditMode() {
        isEditMode = false;
        document.body.classList.remove('is-editing');
        editBtn.classList.remove('hidden');
        editActions.classList.add('hidden');
        if (sortableInstance) sortableInstance.destroy();
      }

      // --- Modal/Tabs ---
      const tabs = document.querySelectorAll('.tab-btn');
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          const target = (tab as HTMLElement).dataset.tab;
          document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
          document.getElementById(`${target}-tab`)?.classList.add('active');
        });
      });

      fileInput?.addEventListener('change', () => {
        if (!preview) return;
        preview.innerHTML = '';
        Array.from(fileInput.files || []).forEach(file => {
          const reader = new FileReader();
          reader.onload = (e) => {
            const div = document.createElement('div');
            div.className = 'preview-item';
            div.innerHTML = `<img src="${e.target?.result}" style="width:60px;height:60px;object-fit:cover;border-radius:4px" />`;
            preview.appendChild(div);
          };
          reader.readAsDataURL(file);
        });
      });

      addBtn.addEventListener('click', () => {
        pendingAction = 'IMPORT';
        openModal(importModal);
      });

      // --- GitHub Actions Logic ---
      async function handleGithubAction(action: string, embedKey: string | null, postId: string | null) {
        let token = localStorage.getItem(GITHUB_TOKEN_KEY);
        if (!token) {
          token = prompt('One-time Setup: Please enter your GitHub Personal Access Token:');
          if (token) localStorage.setItem(GITHUB_TOKEN_KEY, token.trim());
          else return;
        }

        const repo = 'RossyKenobi/Test.1';
        try {
          const res = await fetch(`https://api.github.com/repos/${repo}/actions/workflows/sync-instagram.yml/dispatches`, {
            method: 'POST',
            headers: {
              'Accept': 'application/vnd.github.v3+json',
              'Authorization': `token ${token}`
            },
            body: JSON.stringify({ 
              ref: 'master',
              inputs: { action, embed_key: embedKey || '', post_id: postId || '' }
            })
          });

          if (res.ok || res.status === 204) {
             startPollingForProgress(token);
          } else {
             const err = await res.json();
             alert(`Failed: ${err.message}`);
          }
        } catch (e: any) { alert(`Error: ${e.message}`); }
      }

      async function startPollingForProgress(token: string) {
        let startTime = Date.now();
        openModal(progressModal);
        progressStatusText.innerText = 'Triggering synchronization...';
        progressBarInner.style.width = '10%';

        const poll = async () => {
          try {
            const res = await fetch(`https://api.github.com/repos/RossyKenobi/Test.1/actions/runs?workflow=sync-instagram.yml&per_page=1`, {
              headers: { 'Authorization': `token ${token}` }
            });
            const data = await res.json();
            const latestRun = data.workflow_runs[0];

            if (latestRun && new Date(latestRun.created_at).getTime() > startTime - 30000) {
              const status = latestRun.status;
              const conclusion = latestRun.conclusion;

              if (status === 'completed') {
                if (conclusion === 'success') {
                  progressStatusText.innerText = 'Sync complete. Rebuilding site...';
                  progressBarInner.style.width = '70%';
                  // Wait for deploy
                  setTimeout(pollDeploy, 5000);
                  return;
                } else {
                  progressStatusText.innerText = `Sync failed.`;
                  return;
                }
              }
              progressStatusText.innerText = `Processing: ${status}...`;
              progressBarInner.style.width = '40%';
            }
            setTimeout(poll, 5000);
          } catch (e) { setTimeout(poll, 5000); }
        };

        const pollDeploy = async () => {
          const res = await fetch(`https://api.github.com/repos/RossyKenobi/Test.1/actions/runs?workflow=deploy.yml&per_page=1`, {
            headers: { 'Authorization': `token ${token}` }
          });
          const data = await res.json();
          const latestDeploy = data.workflow_runs[0];

          if (latestDeploy && new Date(latestDeploy.created_at).getTime() > startTime) {
            if (latestDeploy.status === 'completed') {
              progressBarInner.style.width = '100%';
              progressStatusText.innerText = 'Success! Website updated.';
              refreshPageBtn.classList.add('active');
              return;
            }
          }
          setTimeout(pollDeploy, 5000);
        };

        poll();
      }

      // --- Re-initialize Delete Logic for Edit Mode ---
      document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          pendingAction = 'DELETE';
          pendingPostId = btn.getAttribute('data-id');
          openModal(passwordModal);
        });
      });

      // --- PhotoSwipe Carousel Look (Restored & Custom) ---
      document.querySelectorAll('.gallery-item-wrapper').forEach(wrapper => {
        wrapper.addEventListener('click', (e) => {
          if (isEditMode) return;
          if ((e.target as HTMLElement).closest('.delete-btn')) return;

          e.preventDefault();
          const imagesRaw = wrapper.getAttribute('data-images');
          const captionStr = wrapper.getAttribute('data-caption');
          
          if (imagesRaw) {
             const imagesArray = JSON.parse(imagesRaw);
             const pswpItems = imagesArray.map(imgSrc => ({
               src: imgSrc, width: 0, height: 0, alt: captionStr
             }));
             
             const pswp = new PhotoSwipe({
               dataSource: pswpItems,
               mainScrollEnd: true,
               spacing: window.innerWidth > 768 ? -0.2 : 0.05,
               paddingFn: (viewportSize, itemData, index) => {
                 const pad = window.innerWidth > 768 ? window.innerWidth * 0.15 : 20;
                 return { top: 40, bottom: 80, left: pad, right: pad };
               }
             });
             
             pswp.on('uiRegister', function() {
                pswp.ui.registerElement({
                  name: 'custom-caption',
                  order: 9, isButton: false, appendTo: 'root', html: '',
                  onInit: (el, pswpInstance) => {
                    pswpInstance.on('change', () => {
                      el.innerHTML = captionStr ? captionStr.replace(/\n/g, '<br>') : '';
                    });
                  }
                });
             });
             
             pswp.on('gettingData', (e) => {
               const item = e.data;
               if (item.width > 0) return;
               const img = new Image();
               img.onload = () => {
                 item.width = img.naturalWidth; item.height = img.naturalHeight;
                 pswp.refreshSlideContent(e.index); pswp.updateSize(true);
               };
               img.src = item.src as string;
             });
             pswp.init();
          }
        });
      });

      // --- Local Upload Logic ---
      async function handleLocalUpload() {
        const files = Array.from(fileInput.files || []);
        const caption = (document.getElementById('local-caption-input') as HTMLTextAreaElement).value;
        if (files.length === 0) return;

        let token = localStorage.getItem(GITHUB_TOKEN_KEY);
        if (!token) return;

        openModal(progressModal);
        progressStatusText.innerText = 'Uploading images...';
        progressBarInner.style.width = '10%';

        const repo = 'RossyKenobi/Test.1';
        const timestamp = new Date().getTime();
        const postId = `local-${timestamp}`;
        const imagePaths: string[] = [];

        try {
          for (let i = 0; i < files.length; i++) {
            const file = files[i];
            const content = await fileToBase64(file);
            const fileName = `p_local_${timestamp}_${i}.jpg`;
            const path = `public/images/posts/${fileName}`;
            
            progressStatusText.innerText = `Uploading image ${i+1}/${files.length}...`;
            progressBarInner.style.width = `${10 + (i/files.length) * 40}%`;

            await fetch(`https://api.github.com/repos/${repo}/contents/${path}`, {
              method: 'PUT',
              headers: { 'Authorization': `token ${token}`, 'Accept': 'application/vnd.github.v3+json' },
              body: JSON.stringify({
                message: `Upload image ${fileName}`,
                content: content,
                branch: 'master'
              })
            });
            imagePaths.push(`/images/posts/${fileName}`);
          }

          // Now update posts.json
          progressStatusText.innerText = 'Updating directory...';
          progressBarInner.style.width = '60%';

          const postsRes = await fetch(`https://api.github.com/repos/${repo}/contents/src/data/posts.json`, {
            headers: { 'Authorization': `token ${token}` }
          });
          const postsData = await postsRes.json();
          const existingPosts = JSON.parse(atob(postsData.content));
          
          const newPost = {
            id: postId,
            caption: caption,
            timestamp: new Date().toISOString(),
            images: imagePaths,
            hidden: false,
            category: "General"
          };

          const updatedPosts = [...existingPosts, newPost];

          await fetch(`https://api.github.com/repos/${repo}/contents/src/data/posts.json`, {
            method: 'PUT',
            headers: { 'Authorization': `token ${token}`, 'Accept': 'application/vnd.github.v3+json' },
            body: JSON.stringify({
              message: `Add local post ${postId}`,
              content: btoa(unescape(encodeURIComponent(JSON.stringify(updatedPosts, null, 2)))),
              sha: postsData.sha,
              branch: 'master'
            })
          });

          progressStatusText.innerText = 'Success! Deploying...';
          progressBarInner.style.width = '100%';
          refreshPageBtn.classList.add('active');

        } catch (e: any) {
          progressStatusText.innerText = `Error: ${e.message}`;
        }
      }

      function fileToBase64(file: File): Promise<string> {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.readAsDataURL(file);
          reader.onload = () => resolve((reader.result as string).split(',')[1]);
          reader.onerror = error => reject(error);
        });
      }

      // --- Confirm Import (Unified) ---
      document.getElementById('confirm-import')?.addEventListener('click', () => {
        handleLocalUpload();
        closeModal(importModal);
      });
    </script>
  </body>
</html>
