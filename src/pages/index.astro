---
import '../styles/global.css';
import GalleryPost from '../components/GalleryPost.astro';
import postsData from '../data/posts.json';

const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith('/') ? rawBase : rawBase + '/';
const posts = (postsData || []).map(post => ({
  ...post,
  images: (post.images || []).map(img => `${base}${img.startsWith('/') ? img.slice(1) : img}`)
}));
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Fan's Gallery</title>
    <!-- PhotoSwipe CSS -->
    <link rel="stylesheet" href="https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.css">
  </head>
  <body>
    <!-- Transparent Minimalist Navigation -->
    <nav class="minimal-nav">
      <div class="nav-brand">F.Y.</div>
      <div class="nav-links">
        <a href="#gallery" class="nav-link">Works</a>
        <a href="#contact" class="nav-link">Contact</a>
        <a href="#" id="admin-nav-link" class="nav-link">Admin</a>
      </div>
    </nav>

    <!-- Full-Screen Hero Section -->
    <header class="hero-section">
      <img src={`${base}images/hero_background.jpg`} alt="Hero Photography" class="hero-bg" />
      <div class="hero-content">
        <h1 class="hero-title">Selected Works</h1>
        <p class="hero-subtitle">Visual exploration and storytelling.</p>
      </div>
    </header>

    <div class="gallery-divider hero-divider"></div>

    <main class="gallery-grid" id="gallery">
      {posts.map(post => (
        <GalleryPost post={post} />
      ))}
    </main>

    <div class="gallery-bottom-bar" id="gallery-bottom-bar" style="display: none;">
        <div class="edit-controls">
          <button class="action-btn" id="open-edit-mode">Edit</button>
          <div id="edit-actions" class="hidden" style="display:flex; gap:1.5rem">
            <button class="action-btn" id="cancel-edits">Cancel</button>
            <button class="action-btn confirm" id="add-new-post">Import</button>
            <button class="action-btn confirm" id="save-edits">Done</button>
          </div>
        </div>
      </div>
      <div class="gallery-divider"></div>

    <section id="contact" class="contact-section">
      <div class="contact-container">
        <h2 class="contact-title">Contact</h2>
        <div class="contact-list">
          <div class="contact-item">
            <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <a href="mailto:SMYFY1@OUTLOOK.COM">SMYFY1@OUTLOOK.COM</a>
          </div>
          <div class="contact-item">
            <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            <a href="https://instagram.com/theonlyyff" target="_blank">@THEONLYYFF</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Password Modal (Minimalist) -->
    <div class="modal-overlay" id="password-modal">
      <div class="modal-content">
        <h3 class="modal-title">Verification Required</h3>
        <div class="modal-input-group" style="margin-top:2.5rem;">
          <label class="modal-caption">Enter Administrative Password</label>
          <input type="password" id="password-input" class="modal-input" placeholder="••••••••" />
          <div id="password-error" class="error-msg">Incorrect password.</div>
        </div>
        <div class="modal-actions" style="margin-top:3rem;">
          <button class="modal-btn" id="close-password-modal">Cancel</button>
          <button class="modal-btn confirm" id="submit-password">Verify</button>
        </div>
      </div>
    </div>

    <!-- Import Modal -->
    <div class="modal-overlay" id="import-modal">
      <div class="modal-content" style="max-width: 500px;">
        <h3 class="modal-title" style="margin-bottom: 3rem; letter-spacing: 0.2em;">IMPORT NEW WORK</h3>

        <div id="local-tab" class="tab-content active">
          <div class="modal-input-group">
            <label class="modal-caption" style="margin-bottom: 1.5rem; display: block;">SELECT IMAGES</label>
            <div style="display: flex; align-items: center; justify-content: flex-start; gap: 1rem; margin-bottom: 2.5rem;">
                <label for="local-file-input" class="action-btn confirm" style="cursor: pointer; display: inline-block;">Choose Files</label>
                <span id="file-name-display" style="color: rgba(255,255,255,0.5); font-size: 0.8rem; letter-spacing: 0.1em; font-weight: 300;">No file chosen</span>
            </div>
            <input type="file" id="local-file-input" class="modal-input" multiple accept="image/*" style="display: none;" />
            
            <label class="modal-caption" style="margin-top: 1rem; margin-bottom: 0.5rem; display: block;">ADD A CAPTION</label>
            <input type="text" id="local-caption-input" class="modal-input" placeholder="" style="margin-bottom: 2rem; text-align: left; padding: 0.5rem 0; width: 100%;" />
          </div>
        </div>

        <div class="modal-actions" style="margin-top: 1rem; justify-content: center; gap: 1.5rem;">
          <button class="action-btn" id="close-import-modal">Cancel</button>
          <button class="action-btn confirm" id="confirm-import">Confirm</button>
        </div>
      </div>
    </div>

    <!-- Mini Gallery Edit Modal -->
    <div class="modal-overlay" id="mini-gallery-modal">
      <div class="modal-content" style="max-width: 600px;">
        <h3 class="modal-title">Edit Stack</h3>
        <p class="modal-caption" style="margin-bottom: 0;">Drag to reorder, click × to delete</p>
        <div id="mini-gallery-grid" class="mini-gallery-grid"></div>
        <textarea id="mini-caption-input" class="mini-caption-textarea" placeholder="Stack caption..."></textarea>
        <input type="file" id="mini-file-input" multiple accept="image/*" style="display: none;" />
        <div class="modal-actions" style="margin-top: 2rem; justify-content: flex-end; gap: 1.5rem;">
          <button class="action-btn" id="close-mini-gallery">Cancel</button>
          <button class="action-btn confirm" id="mini-import-btn" style="color: black;">Import</button>
          <button class="action-btn confirm" id="confirm-mini-gallery">Done</button>
        </div>
      </div>
    </div>

    <!-- Confirm Discard Modal -->
    <div class="modal-overlay" id="confirm-discard-modal" style="z-index: 2000;">
      <div class="modal-content">
        <h3 class="modal-title">Discard Changes</h3>
        <p class="modal-caption" style="margin-bottom: 2rem;">All unsaved changes will be discarded. Are you sure you want to cancel?</p>
        <div class="modal-actions" style="justify-content: center; gap: 2rem; margin-top: 2rem;">
          <button class="action-btn" id="cancel-discard-btn">No</button>
          <button class="action-btn confirm" id="confirm-discard-btn" style="color: #e11d48;">Yes, Discard</button>
        </div>
      </div>
    </div>

    <!-- Confirm Delete Modal -->
    <div class="modal-overlay" id="confirm-delete-modal" style="z-index: 2000;">
      <div class="modal-content">
        <h3 class="modal-title">Delete Stack</h3>
        <p class="modal-caption" style="margin-bottom: 2rem;">Are you sure you want to delete this stack? This action cannot be undone.</p>
        <div class="modal-actions" style="justify-content: center; gap: 2rem; margin-top: 2rem;">
          <button class="action-btn" id="cancel-delete-btn">Cancel</button>
          <button class="action-btn confirm" id="confirm-delete-btn" style="color: #e11d48;">Delete</button>
        </div>
      </div>
    </div>

    <!-- GitHub Token Modal -->
    <div class="modal-overlay" id="github-token-modal" style="z-index: 2000;">
      <div class="modal-content">
        <h3 class="modal-title">Authentication</h3>
        <p class="modal-caption" style="margin-bottom: 2rem;">Please enter your GitHub Personal Access Token to continue.</p>
        <div class="modal-input-group" style="margin-top:2.5rem;">
          <input type="password" id="github-token-input" class="modal-input" placeholder="ghp_xxxxxxxx" />
        </div>
        <div class="modal-actions" style="justify-content: center; gap: 2rem; margin-top: 2rem;">
          <button class="action-btn" id="cancel-token-btn">Cancel</button>
          <button class="action-btn confirm" id="save-token-btn">Save</button>
        </div>
      </div>
    </div>

    <!-- Progress Modal -->
    <div class="modal-overlay" id="progress-modal">
      <div class="modal-content">
        <h3 class="modal-title" id="progress-title">Importing...</h3>
        <div class="progress-container">
          <div class="progress-bar" id="progress-bar-inner"></div>
        </div>
        <p class="progress-status" id="progress-status-text">Checking GitHub status...</p>
        <div class="modal-actions" style="justify-content: center;">
          <button class="refresh-btn" id="refresh-page-btn">Refresh to see changes</button>
        </div>
      </div>
    </div>

    <style is:global>
      /* --- Hero Scroll Effect --- */
      .hero-section {
        position: relative;
        height: 100vh;
        width: 100%;
        overflow: hidden;
      }
      .hero-bg {
        position: fixed; /* Parallax effect */
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        object-fit: cover;
        z-index: -2;
      }
      .hero-overlay-blur {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background: rgba(0, 0, 0, 0);
        backdrop-filter: blur(0px);
        -webkit-backdrop-filter: blur(0px);
        z-index: -1;
        pointer-events: none;
        transition: backdrop-filter 0.1s linear, -webkit-backdrop-filter 0.1s linear, background 0.1s linear;
      }

      /* --- Edit Mode Styles --- */
      body.is-editing .gallery-item-wrapper {
        cursor: grab;
      }
      body.is-editing .sortable-ghost {
        opacity: 0.3;
      }
      body.is-editing .sortable-drag {
        cursor: grabbing !important;
      }
      body.is-editing .delete-btn {
        display: flex !important;
        opacity: 1 !important;
        background: #ef4444 !important;
      }
      .hidden { display: none !important; }

      /* --- Contact List --- */
      .contact-list {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 20px;
        margin-bottom: 40px;
      }
      .contact-item {
        display: flex;
        align-items: center;
        gap: 12px;
      }
      .contact-icon {
        width: 20px;
        height: 20px;
        opacity: 0.6;
      }
      .contact-item a {
        font-family: 'Inter', sans-serif;
        font-weight: 500;
        letter-spacing: 0.1em;
        text-decoration: none;
        color: white;
        font-size: 0.9rem;
      }

      /* --- Import Modal Tabs --- */
      .import-tabs {
        display: flex;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        margin-bottom: 24px;
      }
      .tab-btn {
        background: none;
        border: none;
        color: rgba(255,255,255,0.5);
        padding: 12px 24px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: color 0.3s;
      }
      .tab-btn.active {
        color: white;
        border-bottom: 2px solid white;
      }
      .tab-content { display: none; }
      .tab-content.active { display: block; }

      /* --- PhotoSwipe Carousel Look --- */
      .pswp__img {
        border-radius: 4px;
        box-shadow: 0 10px 50px rgba(0,0,0,0.5);
      }
      /* Ensure side images are slightly visible */
      .pswp__item {
        padding: 0 10% !important;
      }

    </style>

    <script>
      import PhotoSwipe from 'photoswipe';
      import Sortable from 'sortablejs';

      // --- Hero Scroll Logic ---
      const heroOverlay = document.createElement('div');
      heroOverlay.className = 'hero-overlay-blur';
      document.body.prepend(heroOverlay);

      const minimalNav = document.querySelector('.minimal-nav') as HTMLElement;
      const heroDivider = document.querySelector('.hero-divider') as HTMLElement;
      let isTicking = false;

      window.addEventListener('scroll', () => {
        if (!isTicking) {
          window.requestAnimationFrame(() => {
            const scrollY = window.scrollY;
            const viewportHeight = window.innerHeight;
            
            // Hero background darken
            const progress = Math.min(scrollY / (viewportHeight * 0.8), 1);
            const opacity = 0.35 + (progress * 0.25);
            heroOverlay.style.background = `rgba(0, 0, 0, ${opacity})`; 
            heroOverlay.style.backdropFilter = `blur(${progress * 20}px)`;
            heroOverlay.style.webkitBackdropFilter = `blur(${progress * 20}px)`;

            // Progressive Nav Blur
            if (minimalNav) {
                const navProgress = Math.min(scrollY / 150, 1);
                minimalNav.style.background = `linear-gradient(to bottom, rgba(14,14,14,${navProgress * 0.98}) 0%, rgba(14,14,14,${navProgress * 0.6}) 40%, transparent 100%)`;
                minimalNav.style.backdropFilter = `blur(${navProgress * 24}px)`;
                minimalNav.style.webkitBackdropFilter = `blur(${navProgress * 24}px)`;
            }

            // Immediate Hero Divider
            if (heroDivider) {
                if (scrollY > 20) heroDivider.classList.add('visible');
                else heroDivider.classList.remove('visible');
            }
            isTicking = false;
          });
          isTicking = true;
        }
      });
      // Initial trigger
      heroOverlay.style.background = `rgba(0, 0, 0, 0.35)`;
      heroOverlay.style.backdropFilter = `blur(0px)`;
      heroOverlay.style.webkitBackdropFilter = `blur(0px)`;

      // --- Modals & DOM Elements Initialization ---
      const passwordModal = document.getElementById('password-modal')!;
      const importModal = document.getElementById('import-modal')!;
      const progressModal = document.getElementById('progress-modal')!;
      const passwordInput = document.getElementById('password-input') as HTMLInputElement;
      const embedKeyInput = document.getElementById('embed-key-input') as HTMLInputElement;
      const fileInput = document.getElementById('local-file-input') as HTMLInputElement;
      const preview = document.getElementById('file-preview')!;
      const progressBarInner = document.getElementById('progress-bar-inner')!;
      const progressStatusText = document.getElementById('progress-status-text')!;
      const progressTitle = document.getElementById('progress-title')!;
      const refreshPageBtn = document.getElementById('refresh-page-btn') as HTMLButtonElement;

      const openModal = (modal: HTMLElement) => {
        modal.classList.add('active');
        document.body.style.overflow = 'hidden';
      };
      const closeModal = (modal: HTMLElement) => {
        modal.classList.remove('active');
        if (passwordInput) passwordInput.value = '';
        if (embedKeyInput) embedKeyInput.value = '';
        if (preview) preview.innerHTML = '';
        if (!document.querySelector('.modal-overlay.active')) {
          document.body.style.overflow = '';
        }
      };

      document.getElementById('close-password-modal')?.addEventListener('click', () => closeModal(passwordModal));
      document.getElementById('close-import-modal')?.addEventListener('click', () => closeModal(importModal));
      refreshPageBtn?.addEventListener('click', () => window.location.reload());

      // --- Edit Mode Logic ---
      const GITHUB_TOKEN_KEY = 'gh_admin_token';
      const PASSWORD = 'steveyfff';
      let isEditMode = false;
      let sortableInstance: any = null;
      let isAdminLoggedIn = sessionStorage.getItem('admin_logged_in') === 'true';
      let pendingAction: 'IMPORT' | 'DELETE' | 'ENTER_EDIT' | 'REORDER' | 'DISCARD_MINI_GALLERY' | 'DISCARD_EDITS' | 'ADMIN_LOGIN' | null = null;
      let pendingPostId: string | null = null;
      let initialOrder: string[] = [];

      const editBtn = document.getElementById('open-edit-mode')!;
      const editActions = document.getElementById('edit-actions')!;
      const saveBtn = document.getElementById('save-edits')!;
      const cancelBtn = document.getElementById('cancel-edits')!;
      const addBtn = document.getElementById('add-new-post')!;
      const adminNavLink = document.getElementById('admin-nav-link')!;
      const galleryBottomBar = document.getElementById('gallery-bottom-bar')!;

      if (isAdminLoggedIn) {
          adminNavLink.textContent = 'Log Out';
          galleryBottomBar.style.display = 'flex';
      }

      const confirmDiscardModal = document.getElementById('confirm-discard-modal')!;
      const confirmDiscardBtn = document.getElementById('confirm-discard-btn')!;
      const cancelDiscardBtn = document.getElementById('cancel-discard-btn')!;

      const confirmDeleteModal = document.getElementById('confirm-delete-modal')!;
      const confirmDeleteBtn = document.getElementById('confirm-delete-btn')!;
      const cancelDeleteBtn = document.getElementById('cancel-delete-btn')!;

      cancelDeleteBtn.addEventListener('click', () => {
        closeModal(confirmDeleteModal);
        pendingPostId = null;
      });

      confirmDeleteBtn.addEventListener('click', () => {
        if (pendingPostId) {
          handleDirectAction('DELETE', pendingPostId);
          closeModal(confirmDeleteModal);
          pendingPostId = null;
        }
      });

      adminNavLink.addEventListener('click', (e) => {
        e.preventDefault();
        if (isAdminLoggedIn) {
          isAdminLoggedIn = false;
          sessionStorage.removeItem('admin_logged_in');
          adminNavLink.textContent = 'Admin';
          galleryBottomBar.style.display = 'none';
          if (isEditMode) exitEditMode();
        } else {
          pendingAction = 'ADMIN_LOGIN';
          openModal(passwordModal);
        }
      });

      editBtn.addEventListener('click', () => {
        if (!isEditMode) {
          enterEditMode();
        }
      });

      cancelBtn.addEventListener('click', () => {
        const orderNodes = Array.from(document.querySelectorAll('.gallery-item-wrapper'));
        const currentOrder = orderNodes.map(node => node.getAttribute('data-id') || '');
        if (currentOrder.join(',') !== initialOrder.join(',')) {
          pendingAction = 'DISCARD_EDITS';
          openModal(confirmDiscardModal);
        } else {
          exitEditMode();
        }
      });

      confirmDiscardBtn.addEventListener('click', () => {
        if (pendingAction === 'DISCARD_MINI_GALLERY') {
            closeModal(confirmDiscardModal);
            closeModal(miniGalleryModal);
            pendingAction = null;
        } else {
            window.location.reload();
        }
      });

      cancelDiscardBtn.addEventListener('click', () => {
        closeModal(confirmDiscardModal);
      });

      // Update password submission
      document.getElementById('submit-password')?.addEventListener('click', () => {
        const passwordInput = document.getElementById('password-input') as HTMLInputElement;
        const errorEl = document.getElementById('password-error')!;
        if (passwordInput.value === PASSWORD) {
          errorEl.classList.remove('show');
          closeModal(passwordModal);
          
          if (pendingAction === 'ADMIN_LOGIN') {
            isAdminLoggedIn = true;
            sessionStorage.setItem('admin_logged_in', 'true');
            adminNavLink.textContent = 'Log Out';
            galleryBottomBar.style.display = 'flex';
          } else if (pendingAction === 'ENTER_EDIT') {
            enterEditMode();
          } else if (pendingAction === 'IMPORT') {
            openModal(importModal);
          }
        } else {
          errorEl.classList.add('show');
        }
      });

      function enterEditMode() {
        isEditMode = true;
        document.body.classList.add('is-editing');
        editBtn.classList.add('hidden');
        editActions.classList.remove('hidden');

        const orderNodes = Array.from(document.querySelectorAll('.gallery-item-wrapper'));
        initialOrder = orderNodes.map(node => node.getAttribute('data-id') || '');

        const el = document.getElementById('gallery')!;
        sortableInstance = new Sortable(el, {
          animation: 150,
          ghostClass: 'sortable-ghost',
          onEnd: () => {
             if (typeof resizeAllGridItems === 'function') resizeAllGridItems();
          }
        });
        
        setTimeout(() => { if (typeof resizeAllGridItems === 'function') resizeAllGridItems(); }, 50);
      }

      saveBtn.addEventListener('click', async () => {
        const orderNodes = Array.from(document.querySelectorAll('.gallery-item-wrapper'));
        const newOrder = orderNodes.map(node => node.getAttribute('data-id') || '');
        
        if (newOrder.join(',') === initialOrder.join(',')) {
          console.log("No changes detected. Exiting edit mode silently.");
          exitEditMode();
          return;
        }
        
        // We'll trigger an API call to reorder the JSON
        handleDirectAction('REORDER', newOrder);
        exitEditMode();
      });

      function exitEditMode() {
        isEditMode = false;
        document.body.classList.remove('is-editing');
        editBtn.classList.remove('hidden');
        editActions.classList.add('hidden');
        if (sortableInstance) sortableInstance.destroy();
        
        setTimeout(() => { if (typeof resizeAllGridItems === 'function') resizeAllGridItems(); }, 50);
      }

      // --- Modal/Tabs ---
      const tabs = document.querySelectorAll('.tab-btn');
      tabs.forEach(tab => {
        tab.addEventListener('click', () => {
          tabs.forEach(t => t.classList.remove('active'));
          tab.classList.add('active');
          const target = (tab as HTMLElement).dataset.tab;
          document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
          document.getElementById(`${target}-tab`)?.classList.add('active');
        });
      });

      fileInput?.addEventListener('change', () => {
        const fileNameDisplay = document.getElementById('file-name-display');
        if (fileInput.files && fileInput.files.length > 0) {
          const count = fileInput.files.length;
          if (fileNameDisplay) fileNameDisplay.textContent = `${count} file${count > 1 ? 's' : ''} chosen`;
        } else {
           if (fileNameDisplay) fileNameDisplay.textContent = 'No file chosen';
        }

        if (!preview) return;
        preview.innerHTML = '';
        Array.from(fileInput.files || []).forEach(file => {
          const reader = new FileReader();
          reader.onload = (e) => {
            const div = document.createElement('div');
            div.className = 'preview-item';
            div.innerHTML = `<img src="${e.target?.result}" style="width:60px;height:60px;object-fit:cover;border-radius:4px" />`;
            preview.appendChild(div);
          };
          reader.readAsDataURL(file);
        });
      });

      addBtn.addEventListener('click', () => {
        pendingAction = 'IMPORT';
        openModal(importModal);
      });

      function promptForToken(): Promise<string | null> {
        return new Promise((resolve) => {
          const tokenModal = document.getElementById('github-token-modal')!;
          const copyInput = document.getElementById('github-token-input') as HTMLInputElement;
          copyInput.value = '';
          openModal(tokenModal);

          const handleSave = () => {
            const val = copyInput.value.trim();
            closeModal(tokenModal);
            cleanup();
            resolve(val || null);
          };

          const handleCancel = () => {
            closeModal(tokenModal);
            cleanup();
            resolve(null);
          };

          const saveBtn = document.getElementById('save-token-btn')!;
          const cancelBtn = document.getElementById('cancel-token-btn')!;
          
          saveBtn.addEventListener('click', handleSave);
          cancelBtn.addEventListener('click', handleCancel);

          function cleanup() {
            saveBtn.removeEventListener('click', handleSave);
            cancelBtn.removeEventListener('click', handleCancel);
          }
        });
      }

      // --- Direct GitHub API Actions Logic ---
      async function handleDirectAction(action: string, payload: any) {
        let token = localStorage.getItem(GITHUB_TOKEN_KEY);
        if (!token) {
          token = await promptForToken();
          if (token) localStorage.setItem(GITHUB_TOKEN_KEY, token.trim());
          else return;
        }

        const repo = 'RossyKenobi/Test.1';
        openModal(progressModal);
        
        const progressTitle = document.getElementById('progress-title')!;
        if (action === 'DELETE') progressTitle.innerText = 'Deleting Post...';
        else if (action === 'REORDER') progressTitle.innerText = 'Saving Order...';
        else progressTitle.innerText = 'Working...';
        
        progressStatusText.innerText = 'Fetching latest data...';
        progressBarInner.style.width = '20%';

        try {
          const postsRes = await fetch(`https://api.github.com/repos/${repo}/contents/src/data/posts.json`, {
            headers: { 'Authorization': `token ${token}` }
          });
          const postsData = await postsRes.json();
          const existingPosts = JSON.parse(utf8Decode(postsData.content));
          
          let updatedPosts = existingPosts;
          let message = "Update posts.json";
          
          if (action === 'DELETE') {
             const postId = payload;
             updatedPosts = existingPosts.filter((p: any) => p.id !== postId);
             message = `Delete post ${postId}`;
          } else if (action === 'REORDER') {
             const newOrder = payload;
             const orderedPosts = newOrder.map((id: string) => existingPosts.find((p: any) => p.id === id)).filter(Boolean);
             const missingPosts = existingPosts.filter((p: any) => !newOrder.includes(p.id));
             updatedPosts = [...orderedPosts, ...missingPosts];
             message = `Reorder gallery posts`;
          }

          progressStatusText.innerText = 'Updating repository...';
          progressBarInner.style.width = '60%';

          await fetch(`https://api.github.com/repos/${repo}/contents/src/data/posts.json`, {
            method: 'PUT',
            headers: { 'Authorization': `token ${token}`, 'Accept': 'application/vnd.github.v3+json' },
            body: JSON.stringify({
              message: message,
              content: utf8Encode(JSON.stringify(updatedPosts, null, 2)),
              sha: postsData.sha,
              branch: 'master'
            })
          });
          
          progressStatusText.innerText = 'Waiting for Deploy Action to finish...';
          progressBarInner.style.width = '80%';
          
          const startTime = Date.now();
          const pollDeploy = async () => {
            const res = await fetch(`https://api.github.com/repos/${repo}/actions/runs?workflow=deploy.yml&per_page=1`, {
              headers: { 'Authorization': `token ${token}` }
            });
            const data = await res.json();
            const latestDeploy = data.workflow_runs[0];
            
            if (latestDeploy && new Date(latestDeploy.created_at).getTime() > startTime) {
              if (latestDeploy.status === 'completed') {
                  progressBarInner.style.width = '100%';
                  progressStatusText.innerText = 'Success! Website updated.';
                  refreshPageBtn.classList.add('active');
                  return;
              }
            }
            setTimeout(pollDeploy, 5000);
          };
          setTimeout(pollDeploy, 5000);
          
        } catch (e: any) {
           progressStatusText.innerText = `Error: ${e.message}`;
        }
      }

      // --- Re-initialize Delete Logic for Edit Mode ---
      document.querySelectorAll('.delete-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
          e.preventDefault();
          e.stopPropagation();
          pendingPostId = btn.getAttribute('data-id');
          openModal(confirmDeleteModal);
        });
      });

      // --- PhotoSwipe Carousel Look (Restored & Custom) ---
      // --- Gallery Interactions & Mini-Gallery Modal ---
      const miniGalleryModal = document.getElementById('mini-gallery-modal')!;
      const closeMiniGalleryBtn = document.getElementById('close-mini-gallery')!;
      const confirmMiniGalleryBtn = document.getElementById('confirm-mini-gallery')!;
      const miniGalleryGrid = document.getElementById('mini-gallery-grid')!;
      const miniCaptionInput = document.getElementById('mini-caption-input') as HTMLTextAreaElement;
      let currentEditingWrapper: HTMLElement | null = null;
      let currentMiniImages: string[] = [];
      let originalMiniImages: string = "";
      let originalMiniCaption: string = "";

      function renderMiniGallery() {
          miniGalleryGrid.innerHTML = '';
          currentMiniImages.forEach((src, idx) => {
              const div = document.createElement('div');
              div.className = 'mini-gallery-item';
              div.innerHTML = `
                  <img src="${src}" alt="img ${idx}" draggable="false" style="pointer-events: none;" />
                  <button class="mini-delete-btn" data-idx="${idx}">×</button>
              `;
              miniGalleryGrid.appendChild(div);
          });
          
          miniGalleryGrid.querySelectorAll('.mini-delete-btn').forEach(btn => {
              btn.addEventListener('click', (e) => {
                  const idx = parseInt((e.currentTarget as HTMLElement).getAttribute('data-idx')!);
                  currentMiniImages.splice(idx, 1);
                  renderMiniGallery();
              });
          });
      }

      new Sortable(miniGalleryGrid, {
          animation: 150,
          onEnd: (evt: any) => {
              const el = currentMiniImages.splice(evt.oldIndex, 1)[0];
              currentMiniImages.splice(evt.newIndex, 0, el);
          }
      });

      const miniImportBtn = document.getElementById('mini-import-btn')!;
      const miniFileInput = document.getElementById('mini-file-input') as HTMLInputElement;

      miniImportBtn.addEventListener('click', () => miniFileInput.click());
      miniFileInput.addEventListener('change', (e) => {
          const files = (e.target as HTMLInputElement).files;
          if (!files) return;
          Array.from(files).forEach(file => {
             const reader = new FileReader();
             reader.onload = (re) => {
                 currentMiniImages.push(re.target!.result as string);
                 renderMiniGallery();
             };
             reader.readAsDataURL(file);
          });
      });

      closeMiniGalleryBtn.addEventListener('click', () => {
          const hasChanges = JSON.stringify(currentMiniImages) !== originalMiniImages || miniCaptionInput.value !== originalMiniCaption;
          if (hasChanges) {
              pendingAction = 'DISCARD_MINI_GALLERY';
              openModal(confirmDiscardModal);
          } else {
              closeModal(miniGalleryModal);
          }
      });

      confirmMiniGalleryBtn.addEventListener('click', async () => {
          if (!currentEditingWrapper) { closeModal(miniGalleryModal); return; }

          const postId = currentEditingWrapper.getAttribute('data-id')!;
          const newCaption = miniCaptionInput.value;
          const hasChanges = JSON.stringify(currentMiniImages) !== originalMiniImages || newCaption !== originalMiniCaption;

          if (!hasChanges) { closeModal(miniGalleryModal); return; }

          // Check for new images (data URLs that need uploading)
          const newDataUrls: { idx: number; dataUrl: string }[] = [];
          currentMiniImages.forEach((src, idx) => {
              if (src.startsWith('data:')) {
                  newDataUrls.push({ idx, dataUrl: src });
              }
          });

          let token = localStorage.getItem(GITHUB_TOKEN_KEY);
          if (!token) {
              token = await promptForToken();
              if (token) localStorage.setItem(GITHUB_TOKEN_KEY, token.trim());
              else return;
          }

          closeModal(miniGalleryModal);
          const repo = 'RossyKenobi/Test.1';
          const progressTitle = document.getElementById('progress-title')!;
          progressTitle.innerText = 'Updating Stack...';
          openModal(progressModal);
          progressStatusText.innerText = 'Uploading new images...';
          progressBarInner.style.width = '10%';

          try {
              const timestamp = Date.now();
              // Upload new images
              for (let i = 0; i < newDataUrls.length; i++) {
                  const { idx, dataUrl } = newDataUrls[i];
                  const base64Content = dataUrl.split(',')[1];
                  const fileName = `p_${postId}_add_${timestamp}_${i}.jpg`;
                  const path = `public/images/posts/${fileName}`;

                  progressStatusText.innerText = `Uploading image ${i + 1}/${newDataUrls.length}...`;
                  progressBarInner.style.width = `${10 + ((i + 1) / newDataUrls.length) * 40}%`;

                  await fetch(`https://api.github.com/repos/${repo}/contents/${path}`, {
                      method: 'PUT',
                      headers: { 'Authorization': `token ${token}`, 'Accept': 'application/vnd.github.v3+json' },
                      body: JSON.stringify({
                          message: `Upload mini-gallery image ${fileName}`,
                          content: base64Content,
                          branch: 'master'
                      })
                  });

                  // Replace data URL with the real path
                  currentMiniImages[idx] = `/images/posts/${fileName}`;
              }

              // Now update posts.json
              progressStatusText.innerText = 'Updating gallery data...';
              progressBarInner.style.width = '60%';

              const postsRes = await fetch(`https://api.github.com/repos/${repo}/contents/src/data/posts.json`, {
                  headers: { 'Authorization': `token ${token}` }
              });
              const postsData = await postsRes.json();
              const existingPosts = JSON.parse(utf8Decode(postsData.content));

              const updatedPosts = existingPosts.map((p: any) => {
                  if (p.id === postId) {
                      return { ...p, images: [...currentMiniImages], caption: newCaption };
                  }
                  return p;
              });

              await fetch(`https://api.github.com/repos/${repo}/contents/src/data/posts.json`, {
                  method: 'PUT',
                  headers: { 'Authorization': `token ${token}`, 'Accept': 'application/vnd.github.v3+json' },
                  body: JSON.stringify({
                      message: `Update stack ${postId}`,
                      content: utf8Encode(JSON.stringify(updatedPosts, null, 2)),
                      sha: postsData.sha,
                      branch: 'master'
                  })
              });

              progressStatusText.innerText = 'Waiting for deploy...';
              progressBarInner.style.width = '80%';

              const startTime = Date.now();
              const pollDeploy = async () => {
                  const res = await fetch(`https://api.github.com/repos/${repo}/actions/runs?workflow=deploy.yml&per_page=1`, {
                      headers: { 'Authorization': `token ${token}` }
                  });
                  const data = await res.json();
                  const latestDeploy = data.workflow_runs[0];
                  if (latestDeploy && new Date(latestDeploy.created_at).getTime() > startTime) {
                      if (latestDeploy.status === 'completed') {
                          progressBarInner.style.width = '100%';
                          progressStatusText.innerText = 'Success! Website updated.';
                          refreshPageBtn.classList.add('active');
                          return;
                      }
                  }
                  setTimeout(pollDeploy, 5000);
              };
              setTimeout(pollDeploy, 5000);

          } catch (e: any) {
              progressStatusText.innerText = `Error: ${e.message}`;
          }
      });

      function openMiniGallery(wrapper: HTMLElement) {
          currentEditingWrapper = wrapper;
          const imagesRaw = wrapper.getAttribute('data-images') || "[]";
          currentMiniImages = JSON.parse(imagesRaw);
          originalMiniImages = JSON.stringify(currentMiniImages);
          miniCaptionInput.value = wrapper.getAttribute('data-caption') || "";
          originalMiniCaption = miniCaptionInput.value;
          renderMiniGallery();
          openModal(miniGalleryModal);
      }

      document.querySelectorAll('.gallery-item-wrapper').forEach(wrapper => {
        wrapper.addEventListener('click', (e) => {
          if (document.body.classList.contains('is-editing')) {
              if ((e.target as HTMLElement).closest('.delete-btn')) return; // Ignore outer delete button
              e.preventDefault();
              e.stopPropagation();
              openMiniGallery(wrapper as HTMLElement);
              return;
          }

          e.preventDefault(); // Prevent native browser navigation to image file
          if (document.body.classList.contains('is-swiping')) return;
          const imagesRaw = wrapper.getAttribute('data-images');
          const captionStr = wrapper.getAttribute('data-caption');
          
          if (imagesRaw) {
             const imagesArray = JSON.parse(imagesRaw);
             const pswpItems = imagesArray.map(imgSrc => ({
               src: imgSrc, width: 0, height: 0, alt: captionStr
             }));
             
             const pswp = new PhotoSwipe({
               dataSource: pswpItems,
               mainScrollEnd: true,
               spacing: window.innerWidth > 768 ? -0.35 : 0.05,
               paddingFn: (viewportSize, itemData, index) => {
                 const pad = window.innerWidth > 768 ? window.innerWidth * 0.22 : 20;
                 return { top: 40, bottom: 80, left: pad, right: pad };
               }
             });

             // Dynamic peeking condition based on image proportion
             const adjustSpacing = () => {
                 if(window.innerWidth <= 768) return; 
                 if(!pswp.currSlide || !pswp.currSlide.data || !pswp.currSlide.data.width) return;
                 const ratio = pswp.currSlide.data.width / pswp.currSlide.data.height;
                 let newSpacing = -0.40; // Default for landscape
                 if (ratio < 0.8) newSpacing = -0.65; // Pull severely for portraits
                 else if (ratio < 1.2) newSpacing = -0.45; // Pull moderately for squares

                 if (pswp.options.spacing !== newSpacing) {
                     pswp.options.spacing = newSpacing;
                     pswp.updateSize(false);
                 }
             };

             pswp.on('change', adjustSpacing);
             pswp.on('firstUpdate', adjustSpacing);
             
             pswp.on('uiRegister', function() {
                pswp.ui.registerElement({
                  name: 'custom-caption',
                  order: 9, isButton: false, appendTo: 'root', html: '',
                  onInit: (el, pswpInstance) => {
                    pswpInstance.on('change', () => {
                      el.innerHTML = captionStr ? captionStr.replace(/\n/g, '<br>') : '';
                    });
                  }
                });
             });
             
             pswp.on('gettingData', (e) => {
               const item = e.data;
               if (item.width > 0) return;
               const img = new Image();
               img.onload = () => {
                 item.width = img.naturalWidth; item.height = img.naturalHeight;
                 pswp.refreshSlideContent(e.index); pswp.updateSize(true);
               };
               img.src = item.src as string;
             });
             pswp.init();
          }
        });
      });

      // --- Local Upload Logic ---
      async function handleLocalUpload() {
        const files = Array.from(fileInput.files || []);
        const caption = (document.getElementById('local-caption-input') as HTMLInputElement).value;
        if (files.length === 0) return;

        let token = localStorage.getItem(GITHUB_TOKEN_KEY);
        if (!token) {
          token = await promptForToken();
          if (token) localStorage.setItem(GITHUB_TOKEN_KEY, token.trim());
          else return;
        }

        openModal(progressModal);
        progressStatusText.innerText = 'Uploading images...';
        progressBarInner.style.width = '10%';

        const repo = 'RossyKenobi/Test.1';
        const timestamp = new Date().getTime();
        const postId = `local-${timestamp}`;
        const imagePaths: string[] = [];

        try {
          for (let i = 0; i < files.length; i++) {
            const file = files[i];
            const content = await fileToBase64(file);
            const fileName = `p_local_${timestamp}_${i}.jpg`;
            const path = `public/images/posts/${fileName}`;
            
            progressStatusText.innerText = `Uploading image ${i+1}/${files.length}...`;
            progressBarInner.style.width = `${10 + (i/files.length) * 40}%`;

            await fetch(`https://api.github.com/repos/${repo}/contents/${path}`, {
              method: 'PUT',
              headers: { 'Authorization': `token ${token}`, 'Accept': 'application/vnd.github.v3+json' },
              body: JSON.stringify({
                message: `Upload image ${fileName}`,
                content: content,
                branch: 'master'
              })
            });
            imagePaths.push(`/images/posts/${fileName}`);
          }

          // Now update posts.json
          progressStatusText.innerText = 'Updating directory...';
          progressBarInner.style.width = '60%';

          const postsRes = await fetch(`https://api.github.com/repos/${repo}/contents/src/data/posts.json`, {
            headers: { 'Authorization': `token ${token}` }
          });
          const postsData = await postsRes.json();
          const existingPosts = JSON.parse(utf8Decode(postsData.content));
          
          const newPost = {
            id: postId,
            caption: caption,
            timestamp: new Date().toISOString(),
            images: imagePaths,
            hidden: false,
            category: "General"
          };

          const updatedPosts = [...existingPosts, newPost];

          await fetch(`https://api.github.com/repos/${repo}/contents/src/data/posts.json`, {
            method: 'PUT',
            headers: { 'Authorization': `token ${token}`, 'Accept': 'application/vnd.github.v3+json' },
            body: JSON.stringify({
              message: `Add local post ${postId}`,
              content: utf8Encode(JSON.stringify(updatedPosts, null, 2)),
              sha: postsData.sha,
              branch: 'master'
            })
          });

          progressStatusText.innerText = 'Success! Deploying...';
          progressBarInner.style.width = '100%';
          refreshPageBtn.classList.add('active');

        } catch (e: any) {
          progressStatusText.innerText = `Error: ${e.message}`;
        }
      }

      function fileToBase64(file: File): Promise<string> {
        return new Promise((resolve, reject) => {
          const reader = new FileReader();
          reader.readAsDataURL(file);
          reader.onload = () => resolve((reader.result as string).split(',')[1]);
          reader.onerror = error => reject(error);
        });
      }

      // --- UTF-8-safe Base64 helpers ---
      function utf8Decode(base64: string): string {
        const binStr = atob(base64);
        const bytes = Uint8Array.from(binStr, c => c.charCodeAt(0));
        return new TextDecoder('utf-8').decode(bytes);
      }

      function utf8Encode(str: string): string {
        const bytes = new TextEncoder().encode(str);
        let binStr = '';
        bytes.forEach(b => binStr += String.fromCharCode(b));
        return btoa(binStr);
      }

      // --- Confirm Import (Unified) ---
      document.getElementById('confirm-import')?.addEventListener('click', () => {
        handleLocalUpload();
        closeModal(importModal);
      });

      // --- Grid Masonry Calculation ---
      window.resizeGridItem = function(item) {
        if (!item) return;
        const target = item.querySelector('.gallery-item');
        if (!target) return;
        // Calculate height. Add 64px (4rem) to account for visual gap between items
        const contentHeight = target.getBoundingClientRect().height;
        const rowSpan = Math.ceil((contentHeight + 64) / 10);
        item.style.gridRowEnd = "span " + rowSpan;
      };

      window.resizeAllGridItems = function() {
        const allItems = document.querySelectorAll('.gallery-item-wrapper');
        allItems.forEach(item => window.resizeGridItem(item));
      };

      window.addEventListener('load', window.resizeAllGridItems);
      window.addEventListener('resize', window.resizeAllGridItems);

      document.querySelectorAll('.gallery-item img').forEach(img => {
        if (img.complete) {
          window.resizeGridItem(img.closest('.gallery-item-wrapper'));
        } else {
          img.addEventListener('load', () => window.resizeGridItem(img.closest('.gallery-item-wrapper')));
        }
      });
    </script>
  </body>
</html>
