---
export const prerender = false;
import '../styles/global.css';
import GalleryShared from '../components/GalleryShared.astro';

const auth = Astro.locals.auth();
const currentUserId = auth?.userId || null;

let isCurrentUserAdmin = false;
let currentUsername = '';
let currentUsernameLower = '';
if (currentUserId) {
  const { isAdmin, ensureUser } = await import('../lib/auth');
  isCurrentUserAdmin = await isAdmin(currentUserId);
  // Sync user data (including username) on every page load
  const dbUser = await ensureUser(currentUserId);
  currentUsernameLower = dbUser?.username || '';
  try {
    const user = await Astro.locals.currentUser();
    currentUsername = (user?.username || user?.firstName || 'User').toUpperCase();
  } catch { currentUsername = 'USER'; }
}

let siteTitle = 'Silent Flânerie';
let siteSubtitle = 'Unscripted drifts through the quotidian.';
try {
  const { sql } = await import('../lib/db');
  const rows = await sql`SELECT key, value FROM site_settings WHERE key IN ('site_title', 'site_subtitle')`;
  rows.forEach(r => {
    if (r.key === 'site_title') siteTitle = r.value;
    if (r.key === 'site_subtitle') siteSubtitle = r.value;
  });
} catch (e) {
  // DB not migrated yet
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>THE GALLERY BY F.Y.</title>
    <!-- PhotoSwipe CSS -->
    <link rel="stylesheet" href="https://unpkg.com/photoswipe@5.4.3/dist/photoswipe.css">
    <!-- Mixed Typography: Montserrat (UI) & Cormorant Garamond (Editorial) -->
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@600;700&family=Montserrat:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- Transparent Minimalist Navigation -->
    <nav class="minimal-nav">
      <a href="/" class="nav-brand">THE GALLERY</a>
      <div class="nav-links">
        <a href="#contact" class="nav-link">Contact</a>
        { !currentUserId ? (
          <button class="nav-link" id="custom-login-btn">Login</button>
        ) : (
          <div class="user-menu-wrapper" style="position: relative;">
            <button class="nav-link user-menu-trigger" id="user-menu-trigger">{currentUsername}</button>
            <div class="user-menu-popover" id="user-menu-popover">
              {currentUsernameLower && (
                <a href={`/u/${currentUsernameLower}`} class="user-menu-item">My Page</a>
              )}
              <button class="user-menu-item" id="user-menu-manage">Account</button>
              <button class="user-menu-item user-menu-signout" id="user-menu-signout">Sign out</button>
            </div>
          </div>
        )}
      </div>
    </nav>

    <!-- Full-Screen Hero Section -->
    <header class="hero-section">
      <img src="/images/hero_background.jpg" alt="Hero Photography" class="hero-bg" />
      <div class="hero-content" style="pointer-events: none;">
        <h1 class="hero-title" id="site-title-edit" contenteditable={isCurrentUserAdmin ? "true" : undefined} spellcheck="false" suppressContentEditableWarning="true" style={(isCurrentUserAdmin ? "cursor: text; " : "") + "pointer-events: auto;"}>{siteTitle}</h1>
        <p class="hero-subtitle" id="site-subtitle-edit" contenteditable={isCurrentUserAdmin ? "true" : undefined} spellcheck="false" suppressContentEditableWarning="true" style={(isCurrentUserAdmin ? "cursor: text; " : "") + "pointer-events: auto;"}>{siteSubtitle}</p>
      </div>
      <div class="scroll-indicator">
        <span>SCROLL</span>
        <svg class="scroll-arrow-full" width="40" height="50" viewBox="0 0 40 50" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="20" y1="0" x2="20" y2="33"></line>
          <polyline points="5 18 20 33 35 18"></polyline>
        </svg>
      </div>
      <div class="gallery-divider hero-divider"></div>
    </header>

    <GalleryShared 
      isAuthenticated={!!currentUserId} 
      showEditControls={!!currentUserId} 
      showInviteModal={true} 
      showClerkModals={true} 
    />

    <section id="contact" class="contact-section">
      <div class="contact-container">
        <h2 class="contact-title">Contact</h2>
        <div class="contact-list">
          <div class="contact-item">
            <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"></path><polyline points="22,6 12,13 2,6"></polyline></svg>
            <a href="mailto:SMYFY1@OUTLOOK.COM">SMYFY1@OUTLOOK.COM</a>
          </div>
          <div class="contact-item">
            <svg class="contact-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            <a href="https://instagram.com/theonlyyff" target="_blank">@THEONLYYFF</a>
          </div>
        </div>
      </div>
    </section>
    
    <footer style="padding: 2rem 0 1rem; text-align: center; color: rgba(255,255,255,0.3); font-size: 0.8rem; letter-spacing: 0.1rem;">
      &copy; 2026 THE GALLERY BY F.Y. | v1.3.0
    </footer>

    <style is:global>
      /* --- Hero Scroll Effect --- */
      .hero-section {
        position: relative;
        height: 100vh;
        width: 100%;
        overflow: hidden;
      }
      .hero-bg {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        object-fit: cover;
        z-index: -2;
      }
      .hero-overlay-blur {
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100vh;
        background: rgba(0, 0, 0, 0);
        backdrop-filter: blur(0px);
        -webkit-backdrop-filter: blur(0px);
        z-index: -1;
        pointer-events: none;
        transition: backdrop-filter 0.1s linear, -webkit-backdrop-filter 0.1s linear, background 0.1s linear;
      }
      [contenteditable="true"]:focus {
        outline: none;
      }

      /* --- Edit Mode Styles --- */
      body.is-editing .gallery-item-wrapper {
        cursor: grab;
      }
      body.is-editing .gallery-item-wrapper::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        border: 1px dashed rgba(255, 255, 255, 0.3);
        border-radius: 24px;
        pointer-events: none;
        z-index: 1;
      }
      body.is-editing .sortable-ghost {
        opacity: 0.3;
      }
      body.is-editing .sortable-drag {
        cursor: grabbing !important;
      }
      body.is-editing .delete-btn {
        display: flex !important;
        opacity: 1 !important;
        background: #ef4444 !important;
        pointer-events: auto !important;
      }
      .hidden { display: none !important; }

      /* --- Import Modal Tabs --- */
      .import-tabs {
        display: flex;
        border-bottom: 1px solid rgba(255,255,255,0.1);
        margin-bottom: 24px;
      }
      .tab-btn {
        background: none;
        border: none;
        color: rgba(255,255,255,0.5);
        padding: 12px 24px;
        cursor: pointer;
        font-size: 0.9rem;
        transition: opacity 0.3s ease, transform 0.2s ease;
      }
      .tab-btn.active {
        color: white;
        border-bottom: 2px solid white;
      }
      .tab-content { display: none; }
      .tab-content.active { display: block; }

      /* --- PhotoSwipe Carousel Look --- */
      .pswp__img {
        border-radius: 4px;
        box-shadow: 0 10px 50px rgba(0,0,0,0.5);
      }
      .pswp__item {
        padding: 0 10% !important;
      }
    </style>

    <script define:vars={{ currentUserId, isCurrentUserAdmin }}>
      window.__AUTH__ = {
        userId: currentUserId,
        isAdmin: isCurrentUserAdmin,
      };
    </script>
    <script>
      import { initGallery } from '../scripts/gallery';
      import { initHeroScroll } from '../scripts/hero-scroll';
      import { initUserMenu, initNavigationInterception, initClerkSignInAndInvite, initClerkTextObserver } from '../scripts/clerk-auth';

      const AUTH = (window as any).__AUTH__ || {};

      // Hero scroll effects
      initHeroScroll();

      // User menu (dropdown)
      initUserMenu();

      // Block Clerk external redirects
      initNavigationInterception();

      // Gallery (main page mode)
      initGallery({
        mode: 'main',
        userId: AUTH.userId || null,
        isAdmin: AUTH.isAdmin || false,
        canSort: AUTH.isAdmin || false,
        postsApiUrl: '/api/posts',
      });

      // Clerk sign-in + invite flow (main page only)
      initClerkSignInAndInvite();

      // Clerk text observer
      initClerkTextObserver();

      // --- Admin Site Settings Edit Logic ---
      if (AUTH.isAdmin) {
        const titleEl = document.getElementById('site-title-edit');
        const subtitleEl = document.getElementById('site-subtitle-edit');
        let textTimeout: any;

        const handleTextChange = () => {
          clearTimeout(textTimeout);
          textTimeout = setTimeout(async () => {
            if (!titleEl || !subtitleEl) return;
            try {
              await fetch('/api/site-settings', {
                method: 'PUT',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                  title: titleEl.innerText.trim(),
                  subtitle: subtitleEl.innerText.trim()
                })
              });
            } catch (e) {
              console.error('Failed to save site text', e);
            }
          }, 800);
        };

        titleEl?.addEventListener('input', handleTextChange);
        subtitleEl?.addEventListener('input', handleTextChange);
        
        const preventEnter = (e: KeyboardEvent) => {
          if (e.key === 'Enter') {
            e.preventDefault();
            (e.target as HTMLElement).blur();
          }
        };
        titleEl?.addEventListener('keydown', preventEnter);
        subtitleEl?.addEventListener('keydown', preventEnter);

        // Allow clicking outside to blur explicitly
        document.addEventListener('click', (e) => {
          if (titleEl && !titleEl.contains(e.target as Node) && 
              subtitleEl && !subtitleEl.contains(e.target as Node)) {
            titleEl.blur();
            subtitleEl.blur();
          }
        });
      }
    </script>
  </body>
</html>
