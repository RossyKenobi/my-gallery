---
export const prerender = false;
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
---
<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Welcome - THE GALLERY</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
  <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <ViewTransitions />
  <style>
    body { background: #0a0a0a; color: white; font-family: sans-serif; display: flex; justify-content: center; align-items: center; height: 100vh; margin: 0; }
  </style>
</head>
<body>
  <div id="status">Finalizing...</div>
  <script>
    const urlParams = new URLSearchParams(window.location.search);
    const inviteId = urlParams.get('inviteId') || localStorage.getItem('clerk_invite_id');
    
    async function finalize() {
      if (inviteId) {
        try {
          const res = await fetch('/api/finalize-registration', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({ inviteId })
          });
          const data = await res.json();
          window.location.href = '/';
        } catch (e) {
          document.getElementById('status').innerText = 'Registration error. Please contact admin.';
        }
      } else {
        window.location.href = '/';
      }
    }
    
    finalize();
  </script>
</body>
</html>
