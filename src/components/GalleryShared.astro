---
/**
 * GalleryShared.astro
 * Shared HTML structure: gallery grid, bottom bar, all modals, and file inputs.
 * Used by both index.astro and /u/[username].astro
 */
interface Props {
  isAuthenticated: boolean;
  showEditControls: boolean;
  showInviteModal?: boolean;
  showClerkModals?: boolean;
  showChangeBgBtn?: boolean;
  showExpandBtn?: boolean;
  alwaysShowBar?: boolean;
  currentUsername?: string;
}

const { isAuthenticated, showEditControls, showInviteModal = false, showClerkModals = false, showChangeBgBtn = false, showExpandBtn = false, alwaysShowBar = false, currentUsername = 'USER' } = Astro.props;
---

<!-- Gallery Grid -->
<main class="gallery-grid" id="gallery">
  <div class="gallery-loading" id="gallery-loading">
    <div class="loading-spinner"></div>
  </div>
</main>

<!-- Gallery Bottom Bar (Edit controls) -->
<div class="gallery-bottom-bar" id="gallery-bottom-bar" style={(isAuthenticated && showEditControls) || alwaysShowBar ? '' : 'display: none;'}>
  <div class="edit-controls">
    {showChangeBgBtn && <button class="action-btn" id="change-bg-btn"><span class="text">Change Background</span></button>}
    {(isAuthenticated && showEditControls) && <button class="action-btn" id="add-new-post"><span class="text">Create Album</span></button>}
    {showExpandBtn && <button class="action-btn" id="expand-gallery-btn"><span class="text">Expand</span></button>}
    {(isAuthenticated && showEditControls) && <button class="action-btn" id="open-edit-mode"><span class="text">Edit</span></button>}
    <div id="edit-actions" class="hidden">
      <button class="action-btn" id="cancel-edits">Cancel</button>
      <button class="action-btn confirm" id="save-edits">Done</button>
    </div>
  </div>
</div>
<div class="gallery-divider"></div>

<!-- Import Modal -->
<div class="modal-overlay" id="import-modal">
  <div class="modal-content">
    <h3 class="modal-title" style="margin-bottom: 0.5rem; letter-spacing: 0.2em;">CREATE NEW ALBUM</h3>
    <p style="color: rgba(255,255,255,0.4); font-size: 0.75rem; letter-spacing: 0.05em; text-align: center; margin-bottom: 2rem;">Import any amount of photos to create a new album.</p>

    <div id="local-tab" class="tab-content active">
      <div class="modal-input-group" style="display: flex; flex-direction: column; gap: 0.75rem;">
        <div id="local-drag-zone" class="drag-drop-zone">
          <div id="local-choose-header" style="display: flex; align-items: center; justify-content: flex-start; gap: 1rem;">
              <label for="local-file-input" class="action-btn confirm" style="cursor: pointer; display: inline-block;">Choose Photos</label>
              <span id="file-name-display" style="color: rgba(255,255,255,0.5); font-size: 0.8rem; letter-spacing: 0.1em; font-weight: 300;">Or drag & drop photos here</span>
          </div>
          <div id="local-preview-grid" class="mini-gallery-grid" style="display: none; margin: 1rem 0 0 0; padding: 0; text-align: left;"></div>
        </div>
        <textarea id="local-caption-input" class="mini-caption-textarea" placeholder="Say Something?" rows="2"></textarea>
      </div>
    </div>

    <div class="modal-actions" style="margin-top: 2.5rem; justify-content: center; gap: 1.5rem;">
      <button class="action-btn" id="close-import-modal">Cancel</button>
      <button class="action-btn confirm" id="confirm-import">Confirm</button>
    </div>
  </div>
</div>

<!-- Mini Gallery Edit Modal -->
<div class="modal-overlay" id="mini-gallery-modal">
  <div class="modal-content">
    <h3 class="modal-title" style="letter-spacing: 0.2em;">EDIT ALBUM</h3>
    <p class="modal-caption" style="margin-bottom: 0;">Drag to reorder, click × to delete. Or drag & drop new photos.</p>
    <div id="mini-gallery-grid" class="mini-gallery-grid drag-drop-zone"></div>
    <textarea id="mini-caption-input" class="mini-caption-textarea" placeholder="Say Something?" rows="2"></textarea>

    <div class="modal-actions" style="margin-top: 2.5rem; justify-content: flex-end; gap: 1.5rem;">
      <button class="action-btn" id="close-mini-gallery">Cancel</button>
      <button class="action-btn confirm" id="mini-import-btn" style="color: black;">Import</button>
      <button class="action-btn confirm" id="confirm-mini-gallery">Done</button>
    </div>
  </div>
</div>

<!-- Confirm Discard Modal -->
<div class="modal-overlay" id="confirm-discard-modal" style="z-index: 2000;">
  <div class="modal-content">
    <h3 class="modal-title">Discard Changes</h3>
    <p class="modal-caption" style="margin-bottom: 2rem;">All unsaved changes will be discarded.<br>Are you sure you want to cancel?</p>
    <div class="modal-actions" style="justify-content: center; gap: 2rem; margin-top: 2rem;">
      <button class="action-btn" id="cancel-discard-btn">No</button>
      <button class="action-btn confirm" id="confirm-discard-btn" style="color: #e11d48;">Yes, Discard</button>
    </div>
  </div>
</div>

<!-- Confirm Delete Modal -->
<div class="modal-overlay" id="confirm-delete-modal" style="z-index: 2000;">
  <div class="modal-content">
    <h3 class="modal-title" style="letter-spacing: 0.2em;">DELETE ALBUM</h3>
    <p class="modal-caption" style="margin-bottom: 1.5rem;">Are you sure you want to delete this album?<br>This action cannot be undone.</p>
    <div id="delete-thumbnails-container" style="display: flex; gap: 0.5rem; justify-content: center; margin-bottom: 2rem; flex-wrap: wrap; max-height: 200px; overflow-y: auto;"></div>
    <div class="modal-actions" style="justify-content: center; gap: 2rem; margin-top: 1rem;">
      <button class="action-btn" id="cancel-delete-btn">Cancel</button>
      <button class="action-btn confirm" id="confirm-delete-btn" style="color: #e11d48;">Delete</button>
    </div>
  </div>
</div>

<!-- Progress Modal -->
<div class="modal-overlay" id="progress-modal">
  <div class="modal-content">
    <h3 class="modal-title" id="progress-title">Importing...</h3>
    <div class="progress-container">
      <div class="progress-bar" id="progress-bar-inner"></div>
    </div>
    <p class="progress-status" id="progress-status-text">Preparing...</p>
    <div class="modal-actions" style="justify-content: center; margin-top: 0.5rem;">
      <button class="refresh-btn" id="refresh-page-btn">Refresh</button>
    </div>
  </div>
</div>

{showInviteModal && (
  <!-- Invite Modal -->
  <div class="modal-overlay" id="invite-modal">
    <div class="modal-content" style="max-width: 400px; padding: 1.5rem 2.5rem 2rem 2.5rem; display: flex; flex-direction: column; align-items: center; justify-content: space-between; min-height: auto;">
      <h3 class="modal-title" style="margin-bottom: 0; font-family: 'Montserrat', sans-serif; letter-spacing: 0.1em; font-weight: 400; text-transform: uppercase;">Invitation</h3>
      
      <div style="width: 100%; position: relative; margin: 1.5rem 0;">
        <input type="text" id="invite-input" placeholder="Enter Invitation Code" style="background: transparent; border: none; border-bottom: 1px solid rgba(255,255,255,0.2); padding: 0.75rem 0; width: 100%; font-size: 1rem; color: white; outline: none; text-align: center; font-family: inherit; letter-spacing: 0.1em;" />
        <div id="invite-error-msg" style="position: absolute; width: 100%; text-align: center; color: #e11d48; font-size: 0.8rem; bottom: -1.5rem; opacity: 0; transition: opacity 0.3s; pointer-events: none;">Invalid Code</div>
      </div>

      <div class="modal-actions" style="justify-content: center; gap: 2rem; margin-top: 0.5rem; width: 100%;">
        <button class="action-btn" id="cancel-invite-btn">Cancel</button>
        <button class="action-btn confirm" id="verify-invite-btn">Verify</button>
      </div>
    </div>
  </div>
)}

{showClerkModals && (
  <Fragment>
    <!-- Custom Signup Modal container -->
    <div class="modal-overlay" id="custom-signup-modal" style="z-index: 2000;">
      <div style="position: relative; width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; flex-direction: column;">
        <div id="clerk-signup-mount"></div>
      </div>
    </div>

    <!-- Custom Signin Modal container -->
    <div class="modal-overlay" id="custom-signin-modal" style="z-index: 2000;">
      <div style="position: relative; width: 100%; height: 100%; display: flex; justify-content: center; align-items: center; flex-direction: column;">
        <div id="clerk-signin-mount"></div>
      </div>
    </div>
  </Fragment>
)}

<!-- File inputs OUTSIDE all modals to prevent file picker from closing modals -->
<input type="file" id="local-file-input" multiple accept="image/*" style="position: absolute; width: 1px; height: 1px; opacity: 0; overflow: hidden; clip: rect(0,0,0,0);" />
<input type="file" id="mini-file-input" multiple accept="image/*" style="position: absolute; width: 1px; height: 1px; opacity: 0; overflow: hidden; clip: rect(0,0,0,0);" />

<!-- Share Modal -->
<div class="modal-overlay" id="share-modal" style="z-index: 100005;">
  <div class="modal-content" style="max-width: 380px; padding: 2.5rem 2rem;">
    <h2 style="font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; margin: 0 0 2rem; text-align: center; color: white;">Share This Moment</h2>
    <div class="share-options" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.5rem; text-align: center;">
      <button class="share-btn" data-network="x" aria-label="X (Twitter)" style="background:none; border:none; color:white; cursor:pointer; padding: 0; display:flex; flex-direction:column; align-items:center; gap: 0.8rem; transition: transform 0.2s;">
        <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,0.05); display: flex; justify-content: center; align-items: center; border: 1px solid rgba(255,255,255,0.1);">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line><path d="M22 2L15 15L22 22H18L13 15L8 22H2L9 9L2 2H6L11 9L16 2H22Z" fill="none"></path></svg>
        </div>
        <span style="font-family: 'Montserrat', sans-serif; font-size: 0.65rem; letter-spacing: 0.1em; opacity: 0.7;">X</span>
      </button>
      <button class="share-btn" data-network="instagram" aria-label="Instagram" style="background:none; border:none; color:white; cursor:pointer; padding: 0; display:flex; flex-direction:column; align-items:center; gap: 0.8rem; transition: transform 0.2s;">
        <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,0.05); display: flex; justify-content: center; align-items: center; border: 1px solid rgba(255,255,255,0.1);">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </div>
        <span style="font-family: 'Montserrat', sans-serif; font-size: 0.65rem; letter-spacing: 0.1em; opacity: 0.7;">INSTAGRAM</span>
      </button>
      <button class="share-btn" data-network="facebook" aria-label="Facebook" style="background:none; border:none; color:white; cursor:pointer; padding: 0; display:flex; flex-direction:column; align-items:center; gap: 0.8rem; transition: transform 0.2s;">
        <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,0.05); display: flex; justify-content: center; align-items: center; border: 1px solid rgba(255,255,255,0.1);">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path></svg>
        </div>
        <span style="font-family: 'Montserrat', sans-serif; font-size: 0.65rem; letter-spacing: 0.1em; opacity: 0.7;">FACEBOOK</span>
      </button>
      <button class="share-btn" data-network="tiktok" aria-label="TikTok" style="background:none; border:none; color:white; cursor:pointer; padding: 0; display:flex; flex-direction:column; align-items:center; gap: 0.8rem; transition: transform 0.2s;">
        <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,0.05); display: flex; justify-content: center; align-items: center; border: 1px solid rgba(255,255,255,0.1);">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"></path><line x1="15" y1="4" x2="15" y2="4.01"></line></svg>
        </div>
        <span style="font-family: 'Montserrat', sans-serif; font-size: 0.65rem; letter-spacing: 0.1em; opacity: 0.7;">TIKTOK</span>
      </button>
      <button class="share-btn" data-network="wechat" aria-label="WeChat" style="background:none; border:none; color:white; cursor:pointer; padding: 0; display:flex; flex-direction:column; align-items:center; gap: 0.8rem; transition: transform 0.2s;">
        <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,0.05); display: flex; justify-content: center; align-items: center; border: 1px solid rgba(255,255,255,0.1);">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 8.5-8.5c4.7 0 8.5 3.8 8.5 8.5z"></path></svg>
        </div>
        <span style="font-family: 'Montserrat', sans-serif; font-size: 0.65rem; letter-spacing: 0.1em; opacity: 0.7;">WECHAT</span>
      </button>
      <button class="share-btn" data-network="weibo" aria-label="Weibo" style="background:none; border:none; color:white; cursor:pointer; padding: 0; display:flex; flex-direction:column; align-items:center; gap: 0.8rem; transition: transform 0.2s;">
        <div style="width: 48px; height: 48px; border-radius: 50%; background: rgba(255,255,255,0.05); display: flex; justify-content: center; align-items: center; border: 1px solid rgba(255,255,255,0.1);">
          <svg viewBox="0 0 24 24" width="20" height="20" stroke="currentColor" stroke-width="1.2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15c-2.76 0-5-1.79-5-4 0-2.21 2.24-4 5-4s5 1.79 5 4c0 2.21-2.24 4-5 4zm4-9c-1.1 0-2 .9-2 2s.9 2 2 2 2-.9 2-2-.9-2-2-2z"></path></svg>
        </div>
        <span style="font-family: 'Montserrat', sans-serif; font-size: 0.65rem; letter-spacing: 0.1em; opacity: 0.7;">WEIBO</span>
      </button>
    </div>
    <div style="margin-top: 2rem; display: flex; justify-content: center;">
      <button class="cancel-btn close-modal" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); color: white; padding: 0.7rem 2.5rem; border-radius: 40px; font-family: 'Montserrat', sans-serif; font-size: 0.75rem; letter-spacing: 0.1em; cursor: pointer; transition: all 0.3s ease;">CANCEL</button>
    </div>
  </div>
</div>

<!-- Undo Delete Toast -->
<div class="system-toast" id="system-toast">
  <span id="system-toast-text">Success</span>
</div>
<div class="undo-toast" id="undo-toast">
  <span id="undo-toast-text">Deleting...</span>
  <button id="undo-toast-btn">Undo</button>
</div>
<script>
  import '../scripts/shareModal';
</script>
